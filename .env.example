# VideoCraft 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============================================
# 应用配置
# ============================================
APP_NAME=VideoCraft
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=sqlite:///./videocraft.db
# 生产环境使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost/videocraft

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# 文件存储配置
# ============================================
# 本地存储路径
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# 阿里云 OSS（可选）
# STORAGE_TYPE=oss
# OSS_ACCESS_KEY_ID=your-access-key
# OSS_ACCESS_KEY_SECRET=your-secret
# OSS_BUCKET=your-bucket
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# ============================================
# 豆包大模型 API 配置
# ============================================
# 火山方舟 API Key
DOUBAO_API_KEY=your-doubao-api-key

# 豆包图片生成（Seedream）
SEEDREAM_MODEL=seedream-2.0
SEEDREAM_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations

# 豆包视频生成（Seedance）
SEEDANCE_MODEL=seedance-2.0
SEEDANCE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/videos/generations

# ============================================
# 后端服务配置
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================
# 前端配置
# ============================================
FRONTEND_DEV_SERVER=http://localhost:5173
API_BASE_URL=http://localhost:8000

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/videocraft.log
